<%- include('partials/head.ejs') %>
    <%- include('partials/nav.ejs') %>

        <main>
            <section id="intro" class="first-section">
                <h1>Popular Operating Systems</h1>
                <div class="main-area">
                    <div class="main-area-left"></div>
                    <div class="main-area-center">
                        <p>Operating systems power almost every digital device we use today — from personal computers to smartphones and servers.</p>
                        <p>Some operating systems are designed for general users, while others are built for developers, businesses, or specialized systems.</p>
                        <img src="img/popular-os.png" alt="OS Components">
                        <p>Below are some of the most widely used operating systems in the world.</p>
                    </div>
                    <div class="main-area-right">
                        <a href="#winda" class="scroll-circle" aria-label="Scroll to next section">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <path d="M12 16.5c-.3 0-.5-.1-.7-.3l-6-6a1 1 0 0 1 1.4-1.4L12 14.1l5.3-5.3a1 1 0 1 1 1.4 1.4l-6 6c-.2.2-.4.3-.7.3z" />
                            </svg>
                        </a>
                    </div>
                </div>
            </section>
            <section id="winda" class="second-section">
                <h1>Microsoft Windows</h1>
                <div class="main-area">
                    <div class="main-area-left"></div>
                    <div class="main-area-center">
                        <p>Microsoft Windows is one of the most widely used desktop operating systems.</p>
                        <img src="img/windows.png" alt="OS MS Windows">
                        <h2>Key Features:</h2>
                        <ul class="no-margin">
                            <li>Graphical User Interface (GUI)</li>
                            <li>Wide software compatibility</li>
                            <li>Strong support for gaming</li>
                            <li>Used in homes, schools, and businesses</li>
                        </ul>
                        <p><strong>Where It's Used: </strong>Personal computers, Business workstations, and Gaming systems.</p>
                        <p>Windows is popular because it is user-friendly and supports a large variety of applications.</p>

                    </div>
                    <div class="main-area-right">

                        <!-- Go to Top (Double Up Arrow) -->
                        <a href="#intro" class="scroll-circle go-to-top" aria-label="Go to top">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <path d="M12 7.5c.3 0 .5.1.7.3l6 6a1 1 0 1 1-1.4 1.4L12 9.9l-5.3 5.3a1 1 0 1 1-1.4-1.4l6-6c.2-.2.4-.3.7-.3z" />
                            </svg>
                        </a>

                        <!-- Go Down (Single Arrow) -->
                        <a href="#linux" class="scroll-circle" aria-label="Scroll down">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <path d="M12 16.5c-.3 0-.5-.1-.7-.3l-6-6a1 1 0 0 1 1.4-1.4L12 14.1l5.3-5.3a1 1 0 1 1 1.4 1.4l-6 6c-.2.2-.4.3-.7.3z" />
                            </svg>
                        </a>

                    </div>
                </div>
            </section>
            <section id="linux" class="third-section">
                <h1>Linux</h1>
                <div class="main-area">
                    <div class="main-area-left"></div>
                    <div class="main-area-center">
                        <p>Linux is an open-source operating system used worldwide.</p>
                        <img src="img/linux.png" alt="OS Linux">
                        <h2>Features:</h2>
                        <ul class="no-margin">
                            <li>Free and customizable</li>
                            <li>Strong security</li>
                            <li>Used for servers and development</li>
                            <li>Many distributions (Ubuntu, Fedora, Debian)</li>
                        </ul>
                        <p>Linux is widely used in servers, cloud computing, and by programmers.</p>
                    </div>
                    <div class="main-area-right">
                        <a href="#intro" class="scroll-circle go-to-top" aria-label="Go to top">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <!-- first arrow -->
                                <path d="M12 5c.3 0 .5.1.7.3l6 6a1 1 0 1 1-1.4 1.4L12 7.4l-5.3 5.3a1 1 0 1 1-1.4-1.4l6-6c.2-.2.4-.3.7-.3z" />
                                <!-- second arrow -->
                                <path d="M12 11c.3 0 .5.1.7.3l6 6a1 1 0 1 1-1.4 1.4L12 13.4l-5.3 5.3a1 1 0 1 1-1.4-1.4l6-6c.2-.2.4-.3.7-.3z" />
                            </svg>
                        </a>
                        <a href="#winda" class="scroll-circle go-back" aria-label="Go up">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <path d="M12 7.5c.3 0 .5.1.7.3l6 6a1 1 0 1 1-1.4 1.4L12 9.9l-5.3 5.3a1 1 0 1 1-1.4-1.4l6-6c.2-.2.4-.3.7-.3z" />
                            </svg>
                        </a>
                        <!-- Go Down (Single Arrow) -->
                        <a href="#mac" class="scroll-circle" aria-label="Scroll down">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <path d="M12 16.5c-.3 0-.5-.1-.7-.3l-6-6a1 1 0 0 1 1.4-1.4L12 14.1l5.3-5.3a1 1 0 1 1 1.4 1.4l-6 6c-.2.2-.4.3-.7.3z" />
                            </svg>
                        </a>
                    </div>
                </div>
            </section>
            <section id="mac" class="fourth-section">
                <h1>macOS</h1>
                <div class="main-area">
                    <div class="main-area-left"></div>
                    <div class="main-area-center">
                        <p>Developed by Apple, macOS runs on Mac computers.</p>
                        <img src="img/mac.png" alt="macOS">
                        <h2>Features:</h2>
                        <ul class="no-margin">
                            <li>Clean and modern interface</li>
                            <li>Strong security</li>
                            <li>Optimized for Apple hardware</li>
                            <li>Popular in creative industries (design, video editing)</li>
                        </ul>
                    </div>
                    <div class="main-area-right">
                        <a href="#intro" class="scroll-circle go-to-top" aria-label="Go to top">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <!-- first arrow -->
                                <path d="M12 5c.3 0 .5.1.7.3l6 6a1 1 0 1 1-1.4 1.4L12 7.4l-5.3 5.3a1 1 0 1 1-1.4-1.4l6-6c.2-.2.4-.3.7-.3z" />
                                <!-- second arrow -->
                                <path d="M12 11c.3 0 .5.1.7.3l6 6a1 1 0 1 1-1.4 1.4L12 13.4l-5.3 5.3a1 1 0 1 1-1.4-1.4l6-6c.2-.2.4-.3.7-.3z" />
                            </svg>
                        </a>
                        <a href="#linux" class="scroll-circle go-back" aria-label="Go up">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <path d="M12 7.5c.3 0 .5.1.7.3l6 6a1 1 0 1 1-1.4 1.4L12 9.9l-5.3 5.3a1 1 0 1 1-1.4-1.4l6-6c.2-.2.4-.3.7-.3z" />
                            </svg>
                        </a>
                        <!-- Go Down (Single Arrow) -->
                        <a href="#android" class="scroll-circle" aria-label="Scroll down">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <path d="M12 16.5c-.3 0-.5-.1-.7-.3l-6-6a1 1 0 0 1 1.4-1.4L12 14.1l5.3-5.3a1 1 0 1 1 1.4 1.4l-6 6c-.2.2-.4.3-.7.3z" />
                            </svg>
                        </a>
                    </div>
                </div>
            </section>
            <section id="android" class="fifth-section">
                <h1>Android</h1>
                <div class="main-area">
                    <div class="main-area-left"></div>
                    <div class="main-area-center">
                        <p>Developed by Google, Android is the most widely used mobile operating system.</p>
                        <img src="img/android.png" alt="Android logo">
                        <h2>Used in:</h2>
                        <ul class="no-margin">
                            <li>Smartphones</li>
                            <li>Tablets</li>
                            <li>Smart TVs</li>
                            <li>Wearable devices</li>
                        </ul>
                    </div>
                    <div class="main-area-right">
                        <a href="#intro" class="scroll-circle go-to-top" aria-label="Go to top">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <!-- first arrow -->
                                <path d="M12 5c.3 0 .5.1.7.3l6 6a1 1 0 1 1-1.4 1.4L12 7.4l-5.3 5.3a1 1 0 1 1-1.4-1.4l6-6c.2-.2.4-.3.7-.3z" />
                                <!-- second arrow -->
                                <path d="M12 11c.3 0 .5.1.7.3l6 6a1 1 0 1 1-1.4 1.4L12 13.4l-5.3 5.3a1 1 0 1 1-1.4-1.4l6-6c.2-.2.4-.3.7-.3z" />
                            </svg>
                        </a>
                        <a href="#mac" class="scroll-circle go-back" aria-label="Go up">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <path d="M12 7.5c.3 0 .5.1.7.3l6 6a1 1 0 1 1-1.4 1.4L12 9.9l-5.3 5.3a1 1 0 1 1-1.4-1.4l6-6c.2-.2.4-.3.7-.3z" />
                            </svg>
                        </a>
                        <!-- Go Down (Single Arrow) -->
                        <a href="#ios" class="scroll-circle" aria-label="Scroll down">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <path d="M12 16.5c-.3 0-.5-.1-.7-.3l-6-6a1 1 0 0 1 1.4-1.4L12 14.1l5.3-5.3a1 1 0 1 1 1.4 1.4l-6 6c-.2.2-.4.3-.7.3z" />
                            </svg>
                        </a>
                    </div>
                </div>
            </section>
            <section class="sixth-section" id="ios">
                <h1>iOS</h1>
                <div class="main-area">
                    <div class="main-area-left"></div>
                    <div class="main-area-center">
                        <p>Developed by Apple, iOS runs on iPhones.</p>
                        <img src="img/ios.png" alt="iOS">
                        <h2>Features:</h2>
                        <ul class="no-margin">
                            <li>Strong security</li>
                            <li>Smooth performance</li>
                            <li>Tight integration with Apple ecosystem</li>
                        </ul>
                        <p class="no-margin small-text  padding-top">
                            <i><strong>Sources:</strong>
                                The information on this page was adapted for educational purposes from
                                <a href="https://www.microsoft.com/windows" target="_blank">Microsoft – Windows Overview</a>,
                                <a href="https://www.apple.com/macos/" target="_blank">Apple – macOS</a>,
                                <a href="https://www.kernel.org/" target="_blank">The Linux Kernel Organization</a>, and
                                <a href="https://www.android.com/" target="_blank">Android Official Site</a>.
                            </i>
                        </p>
                    </div>
                    <div class="main-area-right">
                        <a href="#intro" class="scroll-circle go-to-top" aria-label="Go to top">
                            <svg viewBox="0 0 24 24" class="scroll-icon" aria-hidden="true">
                                <!-- first arrow -->
